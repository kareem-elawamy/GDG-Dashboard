@model IEnumerable<GDG_DashBoard.DAL.Models.Roadmap>
@{
    ViewData["Title"] = "Roadmaps";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Roadmap Management";
}

<div class="max-w-7xl mx-auto space-y-6 mt-4">
    
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl font-bold font-headline tracking-tight text-on-surface mb-1">All Roadmaps</h2>
            <p class="text-on-surface/60 text-sm">Manage learning tracks across the community.</p>
        </div>
        <a asp-action="Create" class="bg-primary px-5 py-2.5 rounded-lg font-medium text-sm text-white gdg-shadow hover:bg-[#1a73e8] transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">add</span>
            Create New Roadmap
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-secondary/10 border border-secondary/20 text-secondary px-4 py-3 rounded-lg flex items-center gap-2 mb-4">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Table -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-surface-container-low text-[10px] uppercase tracking-widest text-on-surface/60 font-bold border-b border-outline-variant">
                    <tr>
                        <th class="px-6 py-4">Title</th>
                        <th class="px-6 py-4">Level</th>
                        <th class="px-6 py-4 text-center">Est. Hours</th>
                        <th class="px-6 py-4 text-center">Levels</th>
                        <th class="px-6 py-4 text-center">Created By</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="px-6 py-8 text-center text-sm text-on-surface/50">No roadmaps created yet. Start by creating a new learning track!</td></tr>
                    }
                    @foreach (var r in Model)
                    {
                        <tr class="hover:bg-surface-container/20 transition-colors">
                            <td class="px-6 py-4">
                                <h6 class="font-bold text-sm text-on-surface mb-0.5">@r.Title</h6>
                                <p class="text-[11px] text-on-surface/50 truncate max-w-xs m-0">@r.Description</p>
                            </td>
                            <td class="px-6 py-4">
                                @{
                                    var levelClasses = r.Level.ToString() switch {
                                        "Beginner" => "bg-secondary/10 text-secondary border-secondary/20",
                                        "Intermediate" => "bg-tertiary/10 text-tertiary border-tertiary/20",
                                        _ => "bg-error/10 text-error border-error/20"
                                    };
                                }
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-wider @levelClasses">
                                    @r.Level
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-on-surface/70 bg-surface-container-low px-2 py-1 rounded border border-outline-variant/30">
                                    <span class="material-symbols-outlined text-[13px]">schedule</span> @r.EstimatedTotalHours h
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="inline-flex items-center px-3 py-1 rounded bg-surface-container-low text-xs font-bold text-on-surface border border-outline-variant/50">
                                    @r.Levels.Count Levels
                                </span>
                            </td>
                             <td class="px-6 py-4 text-sm text-on-surface/70 font-medium text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <div class="w-6 h-6 rounded bg-primary/10 text-primary flex items-center justify-center font-bold uppercase text-[10px]">
                                        @((r.CreatedBy?.UserName ?? "A").Substring(0,1))
                                    </div>
                                    @(r.CreatedBy?.UserName ?? "Admin")
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-action="Details" asp-route-id="@r.Id" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-bold text-primary bg-primary/5 hover:bg-primary/10 transition-colors border border-primary/20">
                                    <span class="material-symbols-outlined text-[14px]">edit_document</span> Manage Content
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
