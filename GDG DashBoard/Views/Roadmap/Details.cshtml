@using GDG_DashBoard.DAL.Eums
@model GDG_DashBoard.DAL.Models.Roadmap
@{
    ViewData["Title"] = Model.Title + " Content";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Roadmap Builder";
}

<div class="max-w-5xl mx-auto space-y-8 mt-4 pb-16">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-wider bg-secondary/10 text-secondary border-secondary/20">@Model.Level</span>
                <span class="text-xs font-bold text-on-surface/50 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">schedule</span> @Model.EstimatedTotalHours h Total</span>
            </div>
            <h2 class="text-3xl font-bold font-headline tracking-tight text-on-surface mb-2">@Model.Title</h2>
            <p class="text-on-surface/70 text-sm max-w-2xl leading-relaxed">@Model.Description</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="px-4 py-2.5 rounded-lg text-sm font-medium text-on-surface border border-outline-variant hover:bg-surface-container transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back
            </a>
            <button onclick="document.getElementById('addLevelModal').classList.remove('hidden')" class="bg-secondary px-5 py-2.5 rounded-lg font-medium text-sm text-white gdg-shadow hover:bg-[#2d9047] transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add_task</span> Add New Level
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-secondary/10 border border-secondary/20 text-secondary px-4 py-3 rounded-lg flex items-center gap-2">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Timeline / Levels -->
    <div class="space-y-6">
        @if (!Model.Levels.Any())
        {
            <div class="bg-white rounded-xl border border-outline-variant shadow-sm p-12 text-center flex flex-col items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-surface-container flex items-center justify-center mb-4 text-outline">
                    <span class="material-symbols-outlined text-3xl">account_tree</span>
                </div>
                <h4 class="font-bold text-lg text-on-surface mb-2">No Levels Yet</h4>
                <p class="text-sm text-on-surface/60 max-w-md mx-auto mb-6">Start building this roadmap by creating the first level (e.g. "Week 1", "Module 1").</p>
                <button onclick="document.getElementById('addLevelModal').classList.remove('hidden')" class="bg-secondary px-6 py-2.5 rounded-lg font-medium text-sm text-white gdg-shadow hover:bg-[#2d9047] transition-all">
                    Create First Level
                </button>
            </div>
        }

        @foreach (var level in Model.Levels.OrderBy(l => l.OrderIndex))
        {
            <div class="bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden relative group">
                <!-- Level Header -->
                <div class="bg-surface-container-low px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-outline-variant">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-[10px] font-black tracking-widest uppercase text-primary bg-primary/10 px-2 py-0.5 rounded">Order: @level.OrderIndex</span>
                            <h3 class="font-bold font-headline text-lg m-0 text-on-surface">@level.Title</h3>
                        </div>
                        @if (!string.IsNullOrEmpty(level.Instructions)) {
                            <p class="text-xs text-on-surface/60 m-0">@level.Instructions</p>
                        }
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="openAddResourceModal('@level.Id')" class="px-3 py-1.5 rounded-lg text-xs font-bold text-primary bg-primary/10 hover:bg-primary/20 transition-colors border border-primary/20 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">add</span> Add Resource
                        </button>
                        <form asp-action="DeleteLevel" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to delete this entire level? All resources will be lost.');">
                            <input type="hidden" name="roadmapId" value="@Model.Id" />
                            <input type="hidden" name="levelId" value="@level.Id" />
                            <button type="submit" class="p-1.5 rounded-lg text-on-surface/40 hover:text-error hover:bg-error/10 transition-colors">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Resources List -->
                <div class="p-4 sm:p-6">
                    @if (!level.Resources.Any())
                    {
                        <div class="bg-surface-container-lowest border border-dashed border-outline-variant rounded-lg p-6 text-center">
                            <p class="text-sm text-on-surface/50 m-0 font-medium">No resources added to this level yet. <button type="button" onclick="openAddResourceModal('@level.Id')" class="text-primary hover:underline">Add one now</button>.</p>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-3">
                            @foreach (var res in level.Resources.OrderBy(r => r.OrderIndex))
                            {
                                var iconType = res.Type switch {
                                    ResourceType.VideoCourse => "play_circle",
                                    ResourceType.Article => "article",
                                    ResourceType.PracticalTask => "code",
                                    ResourceType.Quiz => "quiz",
                                    _ => "link"
                                };
                                var colorClass = res.Type switch {
                                    ResourceType.VideoCourse => "text-error bg-error/10 border-error/20",
                                    ResourceType.Article => "text-primary bg-primary/10 border-primary/20",
                                    ResourceType.PracticalTask => "text-tertiary bg-tertiary/10 border-tertiary/20",
                                    ResourceType.Quiz => "text-secondary bg-secondary/10 border-secondary/20",
                                    _ => "text-on-surface/60 bg-surface-container"
                                };

                                <div class="group/res flex items-center justify-between p-3 rounded-lg border border-outline-variant/50 hover:border-outline-variant hover:bg-surface-container-lowest transition-all">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-lg flex items-center justify-center border @colorClass flex-shrink-0">
                                            <span class="material-symbols-outlined">@iconType</span>
                                        </div>
                                        <div>
                                            <h5 class="font-bold text-sm text-on-surface m-0 mb-0.5">@res.Title</h5>
                                            <div class="flex items-center gap-3 text-[11px] font-medium text-on-surface/50">
                                                <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">schedule</span> @res.EstimatedMinutes min</span>
                                                <span class="uppercase tracking-wider px-1.5 py-0.5 bg-surface-container rounded">@res.Type</span>
                                                <a href="@res.Url" target="_blank" class="text-primary hover:underline flex items-center gap-0.5"><span class="material-symbols-outlined text-[12px]">open_in_new</span> Link</a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2 opacity-0 group-hover/res:opacity-100 transition-opacity">
                                        <span class="text-[10px] font-bold text-on-surface/40 bg-surface-container px-2 py-1 rounded">Idx: @res.OrderIndex</span>
                                        <form asp-action="DeleteResource" method="post" class="m-0" onsubmit="return confirm('Delete this resource?');">
                                            <input type="hidden" name="roadmapId" value="@Model.Id" />
                                            <input type="hidden" name="resourceId" value="@res.Id" />
                                            <button type="submit" class="p-1.5 rounded text-on-surface/40 hover:text-error hover:bg-error/10 transition-colors">
                                                <span class="material-symbols-outlined text-[16px]">close</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- ================= MODALS ================= -->

<!-- ADD LEVEL MODAL -->
<div id="addLevelModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 border border-outline-variant relative">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold font-headline m-0 text-on-surface">Add New Level</h3>
            <button type="button" onclick="document.getElementById('addLevelModal').classList.add('hidden')" class="text-on-surface/50 hover:text-on-surface hover:bg-surface-container rounded-full p-1 transition-colors border-0 bg-transparent">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="AddLevel" method="post" class="space-y-4">
            <input type="hidden" name="roadmapId" value="@Model.Id" />
            
            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Level Title</label>
                <input type="text" name="title" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-secondary focus:ring-1 focus:ring-secondary rounded-lg px-4 py-2.5 text-sm" required placeholder="e.g. Week 1: Introduction" />
            </div>
            
            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Instructions (Optional)</label>
                <textarea name="instructions" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-secondary focus:ring-1 focus:ring-secondary rounded-lg px-4 py-2.5 text-sm" placeholder="Read the articles before starting the video..."></textarea>
            </div>
            
            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Order Index</label>
                <input type="number" name="orderIndex" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-secondary focus:ring-1 focus:ring-secondary rounded-lg px-4 py-2.5 text-sm" value="@(Model.Levels.Count + 1)" required />
                <p class="text-[10px] text-on-surface/50 mt-1">Determines the order of levels.</p>
            </div>

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Knowledge Check Quiz (Optional)</label>
                <select name="quizId" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-secondary focus:ring-1 focus:ring-secondary rounded-lg px-4 py-2.5 text-sm">
                    <option value="">-- No Quiz Required --</option>
                    @if (ViewBag.AvailableQuizzes != null)
                    {
                        foreach (var q in (IEnumerable<GDG_DashBoard.DAL.Models.Quiz>)ViewBag.AvailableQuizzes)
                        {
                            <option value="@q.Id">@q.Title (Pass: @q.PassingScorePercentage%)</option>
                        }
                    }
                </select>
                <p class="text-[10px] text-on-surface/50 mt-1">Users must pass this quiz to complete the level.</p>
            </div>

            <button type="submit" class="w-full bg-secondary text-white py-3 rounded-lg font-bold hover:shadow-lg transition-all active:scale-[0.98] border-0 mt-2">Create Level</button>
        </form>
    </div>
</div>

<!-- ADD RESOURCE MODAL -->
<div id="addResourceModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4 text-on-surface">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-lg p-6 border border-outline-variant relative max-h-[90vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold font-headline m-0 text-on-surface">Add New Resource</h3>
            <button type="button" onclick="document.getElementById('addResourceModal').classList.add('hidden')" class="text-on-surface/50 hover:text-on-surface hover:bg-surface-container rounded-full p-1 transition-colors border-0 bg-transparent">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="AddResource" method="post" class="space-y-4">
            <input type="hidden" name="roadmapId" value="@Model.Id" />
            <input type="hidden" name="levelId" id="modalLevelId" value="" />
            
            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Resource Title</label>
                <input type="text" name="title" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" required placeholder="e.g. Clean Architecture in .NET" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Resource Type</label>
                    <select id="resourceTypeSelect" name="type" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" required onchange="toggleResourceInput()">
                        @foreach(var t in Enum.GetValues(typeof(ResourceType)))
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Estimated Mins</label>
                    <input type="number" name="estimatedMinutes" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" value="15" required />
                </div>
            </div>
            
            <div id="urlInputContainer">
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">URL / Link</label>
                <input type="url" id="resourceUrl" name="url" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" required placeholder="https://..." />
            </div>

            <div id="quizSelectContainer" class="hidden">
                 <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Select Practice Quiz</label>
                 <select id="resourceQuizSelect" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" onchange="updateQuizUrl()">
                     <option value="">-- Choose a Quiz --</option>
                     @if (ViewBag.AvailableQuizzes != null)
                     {
                         foreach(var q in (IEnumerable<GDG_DashBoard.DAL.Models.Quiz>)ViewBag.AvailableQuizzes)
                         {
                             <option value="/Quiz/TakeQuiz/@q.Id?roadmapId=@Model.Id">@q.Title</option>
                         }
                     }
                 </select>
                 <p class="text-[10px] text-on-surface/50 mt-1">This will be added as a practice resource (not a mandatory check).</p>
            </div>

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-1">Order Index</label>
                <input type="number" name="orderIndex" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg px-4 py-2.5 text-sm" value="1" required />
            </div>

            <button type="submit" class="w-full bg-primary text-white py-3 rounded-lg font-bold hover:shadow-lg transition-all active:scale-[0.98] border-0 mt-4">Add Resource</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddResourceModal(levelId) {
            document.getElementById('modalLevelId').value = levelId;
            document.getElementById('addResourceModal').classList.remove('hidden');
        }

        function toggleResourceInput() {
            const type = document.getElementById('resourceTypeSelect').value;
            const urlContainer = document.getElementById('urlInputContainer');
            const quizContainer = document.getElementById('quizSelectContainer');
            const urlInput = document.getElementById('resourceUrl');
            const quizSelect = document.getElementById('resourceQuizSelect');

            if (type === 'Quiz') {
                urlContainer.classList.add('hidden');
                quizContainer.classList.remove('hidden');
                urlInput.removeAttribute('required');
                urlInput.type = 'hidden';
                updateQuizUrl(); 
            } else {
                quizContainer.classList.add('hidden');
                urlContainer.classList.remove('hidden');
                urlInput.setAttribute('required', 'required');
                urlInput.type = 'url';
                if (urlInput.value.includes('/Quiz/TakeQuiz/')) {
                    urlInput.value = '';
                }
            }
        }

        function updateQuizUrl() {
            const quizSelect = document.getElementById('resourceQuizSelect');
            const urlInput = document.getElementById('resourceUrl');
            
            if (quizSelect.value) {
                urlInput.value = quizSelect.value;
            } else {
                urlInput.value = '';
            }
        }
    </script>
}
