@model GDG_DashBoard.DAL.Models.Roadmap

@{
    ViewData["Title"] = Model.Title;
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = Model.Title;

    var completedLevelIds = ViewBag.CompletedLevelIds as HashSet<Guid> ?? new HashSet<Guid>();
    int totalLevels = ViewBag.TotalLevels ?? 0;
    int completedCount = ViewBag.CompletedCount ?? 0;
    int progressPct = totalLevels > 0 ? (int)Math.Round((double)completedCount / totalLevels * 100) : 0;
    bool isEnrolled = ViewBag.IsEnrolled ?? false;
}

@if (isEnrolled)
{
    <!-- ══ STICKY PROGRESS BAR (Enrolled Only) ═══════════════════════════ -->
    <div id="stickyProgress" class="sticky top-0 z-40 bg-white/80 backdrop-blur-xl border-b border-outline-variant/15 px-6 py-3 -mx-4 md:-mx-8 -mt-4 md:-mt-8 mb-8 shadow-sm">
        <div class="max-w-5xl mx-auto flex items-center gap-4">
            <a asp-controller="Member" asp-action="MyRoadmaps" class="w-9 h-9 rounded-xl bg-surface-container-high flex items-center justify-center hover:bg-surface-container-highest transition-colors shrink-0 shadow-sm">
                <span class="material-symbols-outlined text-on-surface/60 text-xl">arrow_back</span>
            </a>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1.5">
                    <h2 class="text-sm font-bold text-on-surface truncate">@Model.Title</h2>
                    <span id="progressText" class="text-xs font-black text-primary tabular-nums">@progressPct%</span>
                </div>
                <div class="w-full h-2 bg-surface-container-highest rounded-full overflow-hidden">
                    <div id="progressBar" class="h-full bg-gradient-to-r from-primary via-[#8ab4f8] to-secondary rounded-full transition-all duration-700 ease-out" style="width: @progressPct%"></div>
                </div>
            </div>
            <span id="progressBadge" class="hidden sm:inline-flex px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider @(progressPct >= 100 ? "bg-secondary/10 text-secondary" : "bg-primary/10 text-primary")">
                @completedCount / @totalLevels
            </span>
        </div>
    </div>
}
else
{
    <!-- ══ READ-ONLY BANNER (Public View) ════════════════════════════════ -->
    <div class="mb-8 -mx-4 md:-mx-8 -mt-4 md:-mt-8 px-6 py-4 bg-gradient-to-r from-tertiary/10 via-tertiary/5 to-transparent border-b border-tertiary/15">
        <div class="max-w-5xl mx-auto flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-tertiary text-2xl">visibility</span>
                <div>
                    <p class="text-sm font-bold text-on-surface">Preview Mode</p>
                    <p class="text-xs text-on-surface/50">Join a cohort studying this roadmap to track your progress.</p>
                </div>
            </div>
            <a asp-controller="Home" asp-action="Index" class="px-5 py-2.5 bg-tertiary text-white rounded-xl text-xs font-bold hover:bg-tertiary/90 transition-all shadow-md active:scale-95 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-white">groups</span> Find a Cohort
            </a>
        </div>
    </div>
}

<div class="max-w-5xl mx-auto px-4 pb-16">

    <!-- ══ ROADMAP HEADER ════════════════════════════════════════════════ -->
    <div class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-3">
            <span class="px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest bg-primary/10 text-primary">@Model.Level</span>
            <span class="text-xs font-bold text-on-surface/40 flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">schedule</span> ~@Model.EstimatedTotalHours hrs
            </span>
            <span class="text-xs font-bold text-on-surface/40 flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">layers</span> @Model.Levels.Count levels
            </span>
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-on-surface/60 text-sm leading-relaxed max-w-3xl">@Model.Description</p>
        }
    </div>

    <!-- ══ VERTICAL TIMELINE / STEPPER ════════════════════════════════ -->
    <div class="relative">
        <!-- Timeline Line -->
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary/20 via-outline-variant/15 to-transparent"></div>

        @{ var orderedLevels = Model.Levels.OrderBy(l => l.OrderIndex).ToList(); }
        @for (int i = 0; i < orderedLevels.Count; i++)
        {
            var level = orderedLevels[i];
            var isCompleted = completedLevelIds.Contains(level.Id);
            var levelIndex = i;

            <div class="relative flex gap-6 mb-10 group" data-level-id="@level.Id">
                <!-- Timeline Node -->
                <div class="relative z-10 shrink-0">
                    @if (isEnrolled)
                    {
                        <button type="button"
                                class="level-toggle w-12 h-12 rounded-2xl border-2 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 active:scale-95 shadow-sm
                                       @(isCompleted ? "bg-secondary border-secondary text-white shadow-lg shadow-secondary/25" : "bg-white border-outline-variant/30 text-on-surface/40 hover:border-primary hover:text-primary hover:shadow-md")"
                                data-level-id="@level.Id"
                                title="@(isCompleted ? "Mark as incomplete" : "Mark as complete")">
                            @if (isCompleted)
                            {
                                <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">check_circle</span>
                            }
                            else
                            {
                                <span class="text-sm font-black">@(levelIndex + 1)</span>
                            }
                        </button>
                    }
                    else
                    {
                        <div class="w-12 h-12 rounded-2xl border-2 border-outline-variant/20 bg-white flex items-center justify-center shadow-sm">
                            <span class="text-sm font-black text-on-surface/30">@(levelIndex + 1)</span>
                        </div>
                    }
                </div>

                <!-- Level Content -->
                <div class="flex-1 pb-2 -mt-0.5">
                    <div class="flex items-center gap-3 mb-1">
                        <h3 class="text-lg font-bold font-headline text-on-surface @(isCompleted ? "line-through opacity-50" : "")">@level.Title</h3>
                        @if (isCompleted)
                        {
                            <span class="px-2.5 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-wider bg-secondary/10 text-secondary">Done</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(level.Instructions))
                    {
                        <p class="text-sm text-on-surface/50 mb-4 max-w-2xl leading-relaxed">@level.Instructions</p>
                    }

                    <!-- Resource Cards -->
                    @if (level.Resources.Any())
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
                            @foreach (var res in level.Resources.OrderBy(r => r.OrderIndex))
                            {
                                string icon = res.Type switch
                                {
                                    GDG_DashBoard.DAL.Eums.ResourceType.VideoCourse => "play_circle",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Article => "article",
                                    GDG_DashBoard.DAL.Eums.ResourceType.PracticalTask => "code",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Quiz => "quiz",
                                    _ => "link"
                                };
                                string typeLabel = res.Type switch
                                {
                                    GDG_DashBoard.DAL.Eums.ResourceType.VideoCourse => "Video",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Article => "Article",
                                    GDG_DashBoard.DAL.Eums.ResourceType.PracticalTask => "Practice",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Quiz => "Quiz",
                                    _ => "Link"
                                };
                                string typeColor = res.Type switch
                                {
                                    GDG_DashBoard.DAL.Eums.ResourceType.VideoCourse => "text-[#ff0000] bg-[#ff0000]/8",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Article => "text-primary bg-primary/8",
                                    GDG_DashBoard.DAL.Eums.ResourceType.PracticalTask => "text-secondary bg-secondary/8",
                                    GDG_DashBoard.DAL.Eums.ResourceType.Quiz => "text-tertiary bg-tertiary/8",
                                    _ => "text-on-surface/50 bg-surface-container-high"
                                };

                                <a href="@res.Url" target="_blank" rel="noopener"
                                   class="flex items-center gap-3.5 p-4 bg-white border border-outline-variant/12 rounded-2xl hover:shadow-lg hover:border-primary/20 hover:-translate-y-0.5 transition-all duration-200 group/card">
                                    <div class="w-11 h-11 rounded-xl @typeColor flex items-center justify-center shrink-0">
                                        <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">@icon</span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h4 class="text-sm font-bold text-on-surface truncate group-hover/card:text-primary transition-colors">@res.Title</h4>
                                        <div class="flex items-center gap-2 mt-0.5">
                                            <span class="text-[10px] font-black uppercase tracking-wider text-on-surface/35">@typeLabel</span>
                                            @if (res.EstimatedMinutes > 0)
                                            {
                                                <span class="text-[10px] font-bold text-on-surface/25">• @res.EstimatedMinutes min</span>
                                            }
                                        </div>
                                    </div>
                                    <span class="material-symbols-outlined text-on-surface/15 group-hover/card:text-primary transition-colors text-lg">open_in_new</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Timeline End Node -->
        <div class="relative flex items-center gap-6">
            <div class="relative z-10 shrink-0 w-12 h-12 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1;">flag</span>
            </div>
            <p class="text-sm font-bold text-on-surface/30 font-headline">End of Roadmap</p>
        </div>
    </div>
</div>

@if (isEnrolled)
{
    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.level-toggle').forEach(btn => {
                    btn.addEventListener('click', async function () {
                        const levelId = this.dataset.levelId;
                        const button = this;
                        button.classList.add('animate-pulse');
                        try {
                            const res = await fetch('/Member/ToggleNodeProgress', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ levelId })
                            });
                            const data = await res.json();
                            if (data.success) {
                                if (data.isCompleted) {
                                    button.className = 'level-toggle w-12 h-12 rounded-2xl border-2 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 active:scale-95 shadow-lg bg-secondary border-secondary text-white shadow-secondary/25';
                                    button.innerHTML = '<span class="material-symbols-outlined text-xl" style="font-variation-settings:\'FILL\' 1;">check_circle</span>';
                                } else {
                                    button.className = 'level-toggle w-12 h-12 rounded-2xl border-2 flex items-center justify-center transition-all duration-300 cursor-pointer hover:scale-110 active:scale-95 shadow-sm bg-white border-outline-variant/30 text-on-surface/40 hover:border-primary hover:text-primary hover:shadow-md';
                                    const idx = Array.from(document.querySelectorAll('.level-toggle')).indexOf(button) + 1;
                                    button.innerHTML = '<span class="text-sm font-black">' + idx + '</span>';
                                }
                                const levelDiv = button.closest('[data-level-id]');
                                const titleEl = levelDiv?.querySelector('h3');
                                const badgeEl = levelDiv?.querySelector('.bg-secondary\\/10');
                                if (titleEl) {
                                    titleEl.classList.toggle('line-through', data.isCompleted);
                                    titleEl.classList.toggle('opacity-50', data.isCompleted);
                                    if (data.isCompleted && !badgeEl) {
                                        const b = document.createElement('span');
                                        b.className = 'px-2.5 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-wider bg-secondary/10 text-secondary';
                                        b.textContent = 'Done';
                                        titleEl.parentElement.appendChild(b);
                                    } else if (!data.isCompleted && badgeEl) {
                                        badgeEl.remove();
                                    }
                                }
                                if (data.percentage !== undefined) {
                                    const bar = document.getElementById('progressBar');
                                    const text = document.getElementById('progressText');
                                    const badge = document.getElementById('progressBadge');
                                    if (bar) bar.style.width = data.percentage + '%';
                                    if (text) text.textContent = data.percentage + '%';
                                    if (badge) badge.textContent = data.completedCount + ' / ' + data.totalLevels;
                                }
                            }
                        } catch (err) {
                            console.error('Toggle failed:', err);
                        } finally {
                            button.classList.remove('animate-pulse');
                        }
                    });
                });
            });
        </script>
    }
}
