@model GDG_DashBoard.BLL.ViewModels.Member.MemberProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "My Profile";
    var profile = Model;
    var dashboard = ViewBag.Dashboard as GDG_DashBoard.BLL.Dtos.Member.MemberDashboardDto;
    int completeness = dashboard?.ProfileCompletenessPercentage ?? 0;
    // SVG ring calculations (radius=54, circumference=339.29)
    double circumference = 339.29;
    double offset = circumference - (circumference * completeness / 100.0);
}

<div class="max-w-7xl mx-auto space-y-10 px-4 py-8 sm:px-6 lg:px-8">

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 rounded-xl bg-secondary/5 border border-secondary/30 flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">check_circle</span>
            <p class="text-sm font-medium text-secondary">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 rounded-xl bg-error/5 border border-error/30 flex items-center gap-3">
            <span class="material-symbols-outlined text-error">error</span>
            <p class="text-sm font-medium text-error">@TempData["ErrorMessage"]</p>
        </div>
    }

    <!-- ══ PROFILE HEADER WITH SVG RING ══════════════════════════════ -->
    <section class="relative bg-surface-container-low rounded-3xl p-8 md:p-10 overflow-hidden border border-outline-variant/10 shadow-sm">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-6">

            <!-- Avatar with SVG Progress Ring -->
            <div class="relative shrink-0">
                <svg width="120" height="120" viewBox="0 0 120 120" class="transform -rotate-90">
                    <circle cx="60" cy="60" r="54" fill="none" stroke="#e5e2e1" stroke-width="6"/>
                    <circle cx="60" cy="60" r="54" fill="none" stroke="url(#ringGradient)" stroke-width="6"
                            stroke-linecap="round" stroke-dasharray="@circumference" stroke-dashoffset="@offset"
                            class="transition-all duration-1000 ease-out"/>
                    <defs>
                        <linearGradient id="ringGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#4285f4"/>
                            <stop offset="100%" stop-color="#34a853"/>
                        </linearGradient>
                    </defs>
                </svg>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-[96px] h-[96px] rounded-full bg-primary/10 flex items-center justify-center overflow-hidden">
                        <span class="text-4xl font-black font-headline text-primary/50">@(Model.FullName?.FirstOrDefault() ?? 'M')</span>
                    </div>
                </div>
                <div class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-surface-container-lowest border-2 border-surface-container-low flex items-center justify-center shadow-sm">
                    <span class="text-[10px] font-black text-primary">@completeness%</span>
                </div>
            </div>

            <div class="flex-1 min-w-0">
                <span class="text-xs font-bold tracking-[0.15em] text-primary uppercase font-headline">GDG Member</span>
                <h1 class="text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface font-headline mt-1 truncate">@profile.FullName</h1>
                <div class="flex flex-wrap items-center gap-3 mt-2 text-on-surface/60 text-sm font-medium">
                    @if (!string.IsNullOrEmpty(profile.Email))
                    {
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">mail</span> @profile.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(profile.Phone))
                    {
                        <span class="w-1 h-1 rounded-full bg-outline-variant/50"></span>
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">phone</span> @profile.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(profile.Location))
                    {
                        <span class="w-1 h-1 rounded-full bg-outline-variant/50"></span>
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-base">location_on</span> @profile.Location</span>
                    }
                </div>
                <div class="mt-4 flex flex-wrap gap-3">
                    <a asp-controller="Member" asp-action="EditProfile" class="px-5 py-2.5 bg-primary text-white rounded-xl font-bold text-sm inline-flex items-center gap-2 hover:bg-primary/90 transition-all shadow-md active:scale-95">
                        <span class="material-symbols-outlined text-sm text-white" style="font-variation-settings:'FILL' 1;">edit_document</span>
                        Edit Profile
                    </a>
                    @if (!string.IsNullOrEmpty(profile.GitHubUrl))
                    {
                        <a href="@profile.GitHubUrl" target="_blank" rel="noopener" class="px-4 py-2.5 bg-on-surface/5 hover:bg-on-surface/10 rounded-xl text-sm font-bold flex items-center gap-2 transition-colors">
                            <span class="material-symbols-outlined text-sm">code</span> GitHub
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(profile.LinkedInUrl))
                    {
                        <a href="@profile.LinkedInUrl" target="_blank" rel="noopener" class="px-4 py-2.5 bg-[#0a66c2]/10 hover:bg-[#0a66c2]/20 rounded-xl text-sm font-bold text-[#0a66c2] flex items-center gap-2 transition-colors">
                            <span class="material-symbols-outlined text-sm">person</span> LinkedIn
                        </a>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ══ ACTIVE DASHBOARD WIDGETS (TOP PRIORITY) ═══════════════════ -->
    @if (dashboard != null)
    {
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <!-- Column 1: Join Cohort -->
            <div class="space-y-6 lg:col-span-1">
                <div class="p-6 bg-gradient-to-br from-primary/8 to-secondary/5 border border-primary/15 shadow-sm rounded-3xl">
                    <h3 class="font-headline font-bold text-lg text-on-surface mb-2 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">group_add</span> Join a Cohort
                    </h3>
                    <p class="text-sm text-on-surface/50 mb-4">Have a Join Code from your mentor?</p>
                    <form asp-controller="Group" asp-action="JoinPost" method="post" class="space-y-3">
                        <input type="text" name="code" id="code" placeholder="e.g. A1B2C3" required class="block w-full px-4 py-3 bg-surface-container-lowest border border-outline-variant/30 rounded-xl focus:border-primary focus:ring-1 focus:ring-primary uppercase text-sm font-bold" />
                        <button type="submit" class="w-full px-4 py-3 bg-on-surface text-surface rounded-xl font-bold hover:bg-on-surface/80 transition-colors shadow-md">
                            Join Group
                        </button>
                    </form>
                </div>
            </div>

            <!-- Column 2: Active Roadmaps -->
            <div class="lg:col-span-1">
                <div class="p-6 bg-surface-container-lowest border border-outline-variant/20 shadow-sm rounded-3xl h-full">
                    <h3 class="font-headline font-bold text-lg mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-secondary">school</span> My Learning Tracks
                    </h3>
                    @if (dashboard.ActiveRoadmaps.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var roadmap in dashboard.ActiveRoadmaps)
                            {
                                <a asp-controller="Member" asp-action="RoadmapDetails" asp-route-id="@roadmap.RoadmapId"
                                   class="block p-4 border border-outline-variant/15 rounded-2xl bg-surface-container-low hover:shadow-md hover:border-primary/20 transition-all group">
                                    <div class="flex items-center justify-between mb-2">
                                        <h4 class="font-bold text-on-surface text-sm group-hover:text-primary transition-colors">@roadmap.Title</h4>
                                        <span class="px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-wider bg-secondary/10 text-secondary">@roadmap.Status</span>
                                    </div>
                                    <div class="flex items-center justify-between mb-1 mt-2">
                                        <span class="text-xs font-bold text-on-surface/40">Progress</span>
                                        <span class="text-xs font-black text-on-surface">@roadmap.ProgressPercentage%</span>
                                    </div>
                                    <div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
                                        <div class="h-full bg-gradient-to-r from-primary to-secondary rounded-full" style="width: @roadmap.ProgressPercentage%"></div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="py-8 text-center text-on-surface/30 flex flex-col items-center">
                            <span class="material-symbols-outlined text-4xl mb-2">menu_book</span>
                            <p class="text-sm font-medium">Not enrolled in any Roadmaps yet.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Column 3: Active Groups -->
            <div class="lg:col-span-1">
                <div class="p-6 bg-surface-container-lowest border border-outline-variant/20 shadow-sm rounded-3xl h-full">
                    <h3 class="font-headline font-bold text-lg mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-tertiary">groups</span> My Community Groups
                    </h3>
                    @if (dashboard.ActiveGroups.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var group in dashboard.ActiveGroups)
                            {
                                <div class="p-4 border border-outline-variant/15 rounded-2xl bg-surface-container-low">
                                    <h4 class="font-bold text-on-surface">@group.Name</h4>
                                    @if (!string.IsNullOrEmpty(group.RoadmapTitle))
                                    {
                                        <p class="mt-1 text-xs text-on-surface/50"><span class="font-bold">Studying:</span> @group.RoadmapTitle</p>
                                    }
                                    <div class="mt-3">
                                        <a asp-controller="Group" asp-action="ViewCohort" asp-route-id="@group.GroupId" class="text-xs font-bold text-primary hover:underline flex items-center gap-1">
                                            View Cohort <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="py-8 text-center text-on-surface/30 flex flex-col items-center">
                            <span class="material-symbols-outlined text-4xl mb-2">groups</span>
                            <p class="text-sm font-medium">No active groups.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ══ LEARNING JOURNEY & ACHIEVEMENTS ═══════════════════════════ -->
    @if (profile.CompletedRoadmaps.Any() || profile.CompletedLevels.Any() || profile.PassedQuizzes.Any())
    {
        <section class="space-y-6">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-2xl text-tertiary">workspace_premium</span>
                <h2 class="text-xl font-bold tracking-tight font-headline">Learning Journey & Achievements</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                
                <!-- Completed Roadmaps -->
                @foreach (var rm in profile.CompletedRoadmaps)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-sm border border-outline-variant/15 flex flex-col items-center text-center relative overflow-hidden group hover:shadow-md transition-all">
                        <div class="absolute inset-0 bg-gradient-to-br from-tertiary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="w-14 h-14 rounded-full bg-tertiary/10 text-tertiary flex items-center justify-center mb-4 shadow-sm border border-tertiary/20">
                            <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1;">emoji_events</span>
                        </div>
                        <h4 class="font-bold text-on-surface mb-1">@rm.Title</h4>
                        <span class="text-[10px] font-black uppercase text-on-surface/40 tracking-widest bg-surface-container py-1 px-2 rounded-md">Roadmap Completed</span>
                        <p class="text-xs font-medium text-on-surface/50 mt-3">@rm.CompletedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                }

                <!-- Completed Levels -->
                @foreach (var lvl in profile.CompletedLevels)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-sm border border-outline-variant/15 flex flex-col items-start relative overflow-hidden group hover:shadow-md transition-all">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-3">
                            <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">flag</span>
                        </div>
                        <h4 class="font-bold text-on-surface mb-1 line-clamp-2">@lvl.LevelTitle</h4>
                        <p class="text-[11px] font-bold text-on-surface/50 mb-3 truncate w-full">in @lvl.RoadmapTitle</p>
                        <div class="mt-auto pt-3 border-t border-outline-variant/10 w-full flex justify-between items-center">
                            <span class="text-[10px] font-black uppercase text-primary tracking-widest">Level</span>
                            <span class="text-[10px] font-medium text-on-surface/40">@lvl.CompletedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                }

                <!-- Passed Quizzes -->
                @foreach (var qz in profile.PassedQuizzes)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-6 shadow-sm border border-outline-variant/15 flex flex-col items-start relative overflow-hidden group hover:shadow-md transition-all">
                        <div class="w-10 h-10 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center mb-3">
                            <span class="material-symbols-outlined text-xl" style="font-variation-settings:'FILL' 1;">psychology</span>
                        </div>
                        <h4 class="font-bold text-on-surface mb-1 line-clamp-2">@qz.Title</h4>
                        <div class="mt-auto pt-3 border-t border-outline-variant/10 w-full flex justify-between items-center">
                            <span class="text-[10px] font-black uppercase text-secondary tracking-widest">Quiz Passed</span>
                            <div class="flex items-center gap-1.5">
                                <span class="text-xs font-black text-secondary">@qz.Score%</span>
                                <span class="text-[9px] font-medium text-on-surface/40">@qz.PassedAt.ToString("MM/dd/yy")</span>
                            </div>
                        </div>
                    </div>
                }

            </div>
        </section>
    }

    <!-- ══ CV / PORTFOLIO DATA (BELOW ACTIVE WIDGETS) ════════════════ -->

    <!-- Professional Summary -->
    @if (!string.IsNullOrEmpty(profile.ProfessionalSummary))
    {
        <div class="bg-surface-container-lowest rounded-3xl p-8 shadow-sm border border-outline-variant/10">
            <div class="flex items-center gap-3 mb-4">
                <span class="material-symbols-outlined text-2xl text-primary">description</span>
                <h3 class="text-xl font-bold font-headline">About</h3>
            </div>
            <p class="text-sm md:text-base text-on-surface/70 leading-relaxed max-w-3xl">@profile.ProfessionalSummary</p>
        </div>
    }

    <!-- SKILLS GRID -->
    @if (profile.TechnicalSkills.Any() || profile.SoftSkills.Any())
    {
        <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @if (profile.TechnicalSkills.Any())
            {
                <div class="bg-surface-container-lowest p-8 rounded-3xl shadow-sm border-t-4 border-primary">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined text-primary">code</span>
                        </div>
                        <h3 class="text-xl font-bold font-headline">Technical Stack</h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var skill in profile.TechnicalSkills)
                        {
                            <span class="px-4 py-2 rounded-xl bg-primary/10 text-primary border border-primary/20 text-sm font-bold tracking-wide cursor-default transition-all hover:bg-primary hover:text-white">@skill</span>
                        }
                    </div>
                </div>
            }
            @if (profile.SoftSkills.Any())
            {
                <div class="bg-surface-container-lowest p-8 rounded-3xl shadow-sm border-t-4 border-secondary">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary">
                            <span class="material-symbols-outlined text-secondary">groups</span>
                        </div>
                        <h3 class="text-xl font-bold font-headline">Soft Skills</h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var skill in profile.SoftSkills)
                        {
                            <span class="px-4 py-2 rounded-xl bg-secondary/10 text-secondary border border-secondary/20 text-sm font-bold tracking-wide cursor-default transition-all hover:bg-secondary hover:text-white">@skill</span>
                        }
                    </div>
                </div>
            }
        </section>
    }

    <!-- EXPERIENCE -->
    @if (profile.Experiences.Any())
    {
        <section class="space-y-6 bg-surface-container-lowest p-8 rounded-3xl shadow-sm border border-outline-variant/10">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-2xl text-primary">work</span>
                <h2 class="text-xl font-bold tracking-tight font-headline">Experience</h2>
            </div>
            <div class="relative space-y-6 before:content-[''] before:absolute before:left-[19px] before:top-4 before:bottom-4 before:w-[2px] before:bg-outline-variant/20">
                @foreach (var exp in profile.Experiences)
                {
                    <div class="relative flex gap-6">
                        <div class="z-10 flex-shrink-0 w-10 h-10 rounded-full bg-white border-4 border-surface-container-lowest flex items-center justify-center shadow-sm">
                            <div class="w-3 h-3 rounded-full bg-primary"></div>
                        </div>
                        <div class="flex-1">
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1 mb-1">
                                <h4 class="text-base font-black text-on-surface font-headline">@exp.Title</h4>
                                @if (!string.IsNullOrEmpty(exp.Period))
                                {
                                    <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-[10px] font-bold text-on-surface/60 tracking-wide uppercase">@exp.Period</span>
                                }
                            </div>
                            <p class="text-primary font-bold tracking-wide text-xs uppercase">@exp.Company</p>
                            @if (!string.IsNullOrEmpty(exp.Description))
                            {
                                <p class="text-sm text-on-surface/60 leading-relaxed max-w-3xl mt-2 whitespace-pre-line">@exp.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- EDUCATION -->
    @if (profile.Educations.Any())
    {
        <section class="space-y-6 bg-surface-container-lowest p-8 rounded-3xl shadow-sm border border-outline-variant/10">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-2xl text-secondary">school</span>
                <h2 class="text-xl font-bold tracking-tight font-headline">Education</h2>
            </div>
            <div class="relative space-y-6 before:content-[''] before:absolute before:left-[19px] before:top-4 before:bottom-4 before:w-[2px] before:bg-outline-variant/20">
                @foreach (var edu in profile.Educations)
                {
                    <div class="relative flex gap-6">
                        <div class="z-10 flex-shrink-0 w-10 h-10 rounded-full bg-white border-4 border-surface-container-lowest flex items-center justify-center shadow-sm">
                            <div class="w-3 h-3 rounded-full bg-secondary"></div>
                        </div>
                        <div class="flex-1">
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1 mb-1">
                                <h4 class="text-base font-black text-on-surface font-headline">@edu.Degree</h4>
                                @if (!string.IsNullOrEmpty(edu.Year))
                                {
                                    <span class="px-3 py-1 bg-surface-container-highest rounded-lg text-[10px] font-bold text-on-surface/60 tracking-wide uppercase">Class of @edu.Year</span>
                                }
                            </div>
                            <p class="text-secondary font-bold tracking-wide text-xs uppercase">@edu.University</p>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- PROJECTS -->
    @if (profile.Projects.Any())
    {
        <section class="space-y-6">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-2xl text-tertiary">tips_and_updates</span>
                <h2 class="text-xl font-bold tracking-tight font-headline">Projects</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                @{ string[] borderColors = { "border-[#fabb05]", "border-[#34a853]", "border-[#ea4335]", "border-[#4285f4]" }; }
                @for (int i = 0; i < profile.Projects.Count; i++)
                {
                    var proj = profile.Projects[i];
                    var bc = borderColors[i % borderColors.Length];
                    <div class="group bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm border-t-4 @bc hover:shadow-xl transition-all flex flex-col p-6">
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <h3 class="text-lg font-bold font-headline mb-1">@proj.Name</h3>
                                @if (!string.IsNullOrEmpty(proj.Period))
                                {
                                    <span class="text-[10px] font-bold text-on-surface/35 uppercase tracking-widest">@proj.Period</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(proj.Url))
                            {
                                <a href="@proj.Url" target="_blank" rel="noopener" class="w-9 h-9 rounded-full bg-surface-container-low flex items-center justify-center hover:bg-primary hover:text-white transition-colors shrink-0">
                                    <span class="material-symbols-outlined text-base">open_in_new</span>
                                </a>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(proj.Description))
                        {
                            <p class="text-sm text-on-surface/60 leading-relaxed flex-1">@proj.Description</p>
                        }
                    </div>
                }
            </div>
        </section>
    }

    <!-- Empty State Fallback -->
    @if (!profile.TechnicalSkills.Any() && !profile.Experiences.Any() && !profile.Educations.Any() && !profile.Projects.Any())
    {
        <div class="text-center py-20 text-on-surface/30 bg-surface-container-lowest rounded-3xl border border-outline-variant/20 border-dashed">
            <span class="material-symbols-outlined text-5xl mb-4 block">person_outline</span>
            <p class="font-bold font-headline text-xl mb-2 text-on-surface/40">Your Portfolio is Empty</p>
            <p class="text-sm font-medium mb-6">Upload your CV using the AI parser to instantly build your professional portfolio.</p>
            <a asp-controller="Member" asp-action="EditProfile" class="px-8 py-3 bg-primary text-white rounded-xl font-bold inline-flex items-center gap-2 hover:bg-primary/90 transition-all shadow-md">
                <span class="material-symbols-outlined text-lg text-white" style="font-variation-settings:'FILL' 1;">edit_document</span>
                Complete Profile Now
            </a>
        </div>
    }
</div>
