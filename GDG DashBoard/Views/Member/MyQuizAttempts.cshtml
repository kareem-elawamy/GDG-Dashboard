@model IEnumerable<GDG_DashBoard.DAL.Models.UserQuizAttempt>
@{
    ViewData["Title"] = "My Quiz Attempts";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Quiz Attempts";
}

<div class="mb-6">
    <h2 class="text-2xl font-black font-headline text-on-surface">My Quiz Attempts</h2>
    <p class="text-sm text-on-surface/50 mt-1">Review your past scores and knowledge check completions.</p>
</div>

<div class="max-w-5xl">
    @if (!Model.Any())
    {
        <div class="bg-white rounded-3xl p-12 text-center shadow-sm border border-outline-variant/20">
            <span class="material-symbols-outlined text-5xl text-on-surface/20 mb-4">history</span>
            <h3 class="text-xl font-bold font-headline text-on-surface mb-2">No Attempts Yet</h3>
            <p class="text-on-surface/60 max-w-sm mx-auto">You haven't taken any quizzes or knowledge checks yet. When you do, your results will appear here.</p>
            <a asp-controller="Member" asp-action="MyRoadmaps" class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-xl font-bold shadow-md hover:-translate-y-0.5 transition-all">
                Browse Roadmaps
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var attempt in Model)
            {
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/20 relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-br from-transparent to-surface-container opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="flex items-start justify-between mb-4">
                            <div class="flex-1">
                                <h3 class="text-lg font-black font-headline text-on-surface group-hover:text-primary transition-colors">@attempt.Quiz?.Title</h3>
                                <p class="text-xs font-bold text-on-surface/40 flex items-center gap-1 mt-1">
                                    <span class="material-symbols-outlined text-[14px]">event</span>
                                    @attempt.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                </p>
                            </div>
                            
                            @if (attempt.IsPassed)
                            {
                                <div class="w-10 h-10 rounded-full bg-secondary/10 text-secondary flex items-center justify-center shrink-0 shadow-sm" title="Passed">
                                    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">check_circle</span>
                                </div>
                            }
                            else
                            {
                                <div class="w-10 h-10 rounded-full bg-error/10 text-error flex items-center justify-center shrink-0 shadow-sm" title="Failed">
                                    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;">cancel</span>
                                </div>
                            }
                        </div>
                        
                        <div class="mt-auto pt-4 border-t border-outline-variant/20 flex items-center justify-between">
                            <span class="text-[10px] font-black uppercase tracking-wider text-on-surface/50">Score</span>
                            <div class="flex items-center gap-2">
                                <span class="text-xl font-black @(attempt.IsPassed ? "text-secondary" : "text-error")">@attempt.ScorePercentage%</span>
                                <span class="text-[10px] font-bold text-on-surface/40 shrink-0">/ Min @attempt.Quiz?.PassingScorePercentage%</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
