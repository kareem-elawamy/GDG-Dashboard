@model GDG_DashBoard.ViewModels.Auth.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – GDG Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/image/gdg_bandung_logo_only.png.png" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#4285f4",
                        "gdg-blue": "#4285f4",
                        "gdg-green": "#34a853",
                        "gdg-yellow": "#f9ab00",
                        "gdg-red": "#ea4335",
                        "on-surface": "#1b1b1c",
                        "surface": "#fcf9f8",
                        "outline-variant": "#c2c6d5",
                        "surface-container": "#f0eded",
                    },
                    fontFamily: {
                        "headline": ["Manrope", "sans-serif"],
                        "body": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        body { font-family: 'Inter', sans-serif; }
        .gdg-dot { width: 8px; height: 8px; border-radius: 50%; }
    </style>
</head>
<body class="min-h-screen bg-surface text-on-surface antialiased">
<div class="min-h-screen flex">

    <!-- ══ LEFT PANEL — BRANDING ══════════════════════════════════════════════ -->
    <div class="hidden lg:flex lg:w-1/2 bg-on-surface flex-col justify-between p-16 relative overflow-hidden">
        <!-- Decorative blobs -->
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-gdg-blue/20 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-gdg-green/20 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 w-48 h-48 bg-gdg-yellow/10 rounded-full blur-2xl"></div>

        <!-- Logo -->
        <div class="relative z-10 flex items-center gap-3">
            <img src="~/image/gdg_bandung_logo_only.png.png" asp-append-version="true" alt="GDG Logo" class="h-10 w-auto" onerror="this.onerror=null; this.src='https://via.placeholder.com/40x40?text=G';" />
            <div>
                <p class="text-white font-bold font-headline text-lg leading-none">GDG Dashboard</p>
                <p class="text-white/40 text-[10px] font-bold uppercase tracking-widest mt-0.5">Google Developer Groups</p>
            </div>
        </div>

        <!-- Center text -->
        <div class="relative z-10">
            <div class="flex items-center gap-2 mb-6">
                <div class="gdg-dot bg-gdg-blue"></div>
                <div class="gdg-dot bg-gdg-red"></div>
                <div class="gdg-dot bg-gdg-yellow"></div>
                <div class="gdg-dot bg-gdg-green"></div>
            </div>
            <h1 class="text-5xl font-extrabold font-headline text-white leading-tight tracking-tight mb-4">
                Welcome<br />Back.
            </h1>
            <p class="text-white/50 text-base leading-relaxed max-w-sm">
                Your internal hub for managing members, tracking roadmap progress, and growing the GDG community.
            </p>
        </div>

        <!-- Bottom stats -->
        <div class="relative z-10 flex gap-8">
            <div>
                <p class="text-2xl font-black text-white font-headline">200+</p>
                <p class="text-white/40 text-xs font-bold uppercase tracking-widest">Members</p>
            </div>
            <div class="w-px bg-white/10"></div>
            <div>
                <p class="text-2xl font-black text-white font-headline">12</p>
                <p class="text-white/40 text-xs font-bold uppercase tracking-widest">Roadmaps</p>
            </div>
            <div class="w-px bg-white/10"></div>
            <div>
                <p class="text-2xl font-black text-gdg-green font-headline">Active</p>
                <p class="text-white/40 text-xs font-bold uppercase tracking-widest">Season</p>
            </div>
        </div>
    </div>

    <!-- ══ RIGHT PANEL — FORM ══════════════════════════════════════════════════ -->
    <div class="flex-1 flex items-center justify-center px-8 py-16 bg-surface">
        <div class="w-full max-w-md">

            <!-- Mobile logo -->
            <div class="lg:hidden flex items-center gap-2 mb-8">
                <img src="~/image/gdg_bandung_logo_only.png.png" asp-append-version="true" alt="GDG Logo" class="h-8 w-auto" onerror="this.onerror=null; this.src='https://via.placeholder.com/32x32?text=G';" />
                <p class="font-bold font-headline text-on-surface">GDG Dashboard</p>
            </div>

            <h2 class="text-3xl font-extrabold font-headline tracking-tight text-on-surface mb-1">Sign in</h2>
            <p class="text-on-surface/50 text-sm mb-10">Internal access only. Contact your admin if you need access.</p>

            <!-- Validation summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 bg-gdg-red/5 border border-gdg-red/20 rounded-xl p-4 flex items-start gap-3">
                    <span class="material-symbols-outlined text-gdg-red text-lg mt-0.5">error</span>
                    <div asp-validation-summary="ModelOnly" class="text-sm text-gdg-red font-medium"></div>
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-xs font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl">mail</span>
                        <input asp-for="Email"
                               class="w-full pl-12 pr-4 py-3.5 bg-surface-container border border-outline-variant rounded-xl text-sm text-on-surface placeholder:text-on-surface/30 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                               placeholder="you@gdg.community"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-xs text-gdg-red mt-1 block"></span>
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password" class="block text-xs font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl">lock</span>
                        <input asp-for="Password" type="password"
                               class="w-full pl-12 pr-12 py-3.5 bg-surface-container border border-outline-variant rounded-xl text-sm text-on-surface placeholder:text-on-surface/30 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                        <button type="button" onclick="togglePassword(this)"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-xs text-gdg-red mt-1 block"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center justify-between">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input asp-for="RememberMe" type="checkbox"
                               class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary/30" />
                        <span class="text-sm text-on-surface/60 group-hover:text-on-surface transition-colors">Remember me for 7 days</span>
                    </label>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full py-4 bg-gdg-blue text-white font-bold rounded-xl text-sm shadow-lg hover:bg-[#1a73e8] hover:shadow-xl active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">login</span>
                    Sign In to Dashboard
                </button>
            </form>

            <!-- Footer note -->
            <p class="text-center text-xs text-on-surface/30 mt-8">
                Restricted access — GDG internal use only.
            </p>
        </div>
    </div>
</div>

<script>
    function togglePassword(btn) {
        const input = btn.closest('.relative').querySelector('input');
        const icon = btn.querySelector('.material-symbols-outlined');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }
</script>
</body>
</html>
