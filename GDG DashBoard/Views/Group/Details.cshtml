@using GDG_DashBoard.DAL.Models
@model GDG_DashBoard.DAL.Models.CommunityGroup
@{
    ViewData["Title"] = Model.Name + " Details";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Group Management";
    var users = ViewBag.AvailableUsers as List<ApplicationUser> ?? new List<ApplicationUser>();
    var roadmaps = ViewBag.AvailableRoadmaps as List<Roadmap> ?? new List<Roadmap>();
}

<div class="max-w-7xl mx-auto space-y-6 mt-4">
    
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl font-bold font-headline tracking-tight text-on-surface mb-1">@Model.Name Dashboard</h2>
            <p class="text-on-surface/60 text-sm">@Model.Description</p>
        </div>
        <a asp-controller="Instructor" asp-action="Index" class="px-4 py-2 rounded-lg font-medium text-sm text-on-surface border border-outline-variant hover:bg-surface-container-high transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Back to Console
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-secondary/10 border border-secondary/20 text-secondary px-4 py-3 rounded-lg flex items-center gap-2">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-medium">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-12">
        
        <!-- Members Panel -->
        <div class="bg-white rounded-xl border border-outline-variant shadow-sm flex flex-col h-full">
            <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center bg-surface-container/30">
                <h4 class="font-bold font-headline text-base m-0 text-on-surface">Group Members</h4>
                <span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded-md">@Model.GroupMembers.Count Enrolled</span>
            </div>
            
            <div class="p-6 flex-1 flex flex-col">
                <div class="border border-outline-variant rounded-lg overflow-hidden mb-6 flex-1">
                    <ul class="divide-y divide-outline-variant max-h-64 overflow-y-auto m-0 p-0 text-sm">
                        @if (!Model.GroupMembers.Any())
                        {
                            <li class="p-6 text-center text-on-surface/40">No members yet.</li>
                        }
                        @foreach (var member in Model.GroupMembers)
                        {
                            <li class="p-3 flex justify-between items-center hover:bg-surface-container-lowest transition-colors">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded bg-primary/10 text-primary flex items-center justify-center font-bold uppercase text-xs">
                                        @((member.Member.UserName ?? member.Member.Email)?.Substring(0,1))
                                    </div>
                                    <span class="font-medium text-on-surface">@(member.Member.UserName ?? member.Member.Email)</span>
                                </div>
                                <span class="text-[10px] text-on-surface/50 font-medium bg-surface-container px-2 py-1 rounded">Joined: @member.JoinedAt.ToShortDateString()</span>
                            </li>
                        }
                    </ul>
                </div>
                
                <div class="mt-auto">
                    <h6 class="font-bold text-sm text-on-surface mb-3">Add New Members</h6>
                    <form asp-action="AddMembers" method="post" class="space-y-3">
                        <input type="hidden" name="groupId" value="@Model.Id" />
                        <div>
                            <select name="memberIds" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-primary focus:ring-1 focus:ring-primary rounded-lg p-2 text-sm text-on-surface" multiple size="4" required>
                                @foreach (var u in users.Where(u => !Model.GroupMembers.Any(gm => gm.MemberId == u.Id)))
                                {
                                    <option value="@u.Id" class="py-1 px-2 mb-1 rounded hover:bg-surface-container">@(u.UserName ?? u.Email)</option>
                                }
                            </select>
                            <p class="text-xs text-on-surface/50 mt-1.5 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">info</span> Hold CTRL (or CMD) to select multiple</p>
                        </div>
                        <button type="submit" class="w-full bg-primary text-white py-2.5 rounded-lg font-medium text-sm hover:bg-[#1a73e8] transition-colors gdg-shadow border-0">Add Selected Members</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Roadmap & Invite Panel Column -->
        <div class="flex flex-col gap-6 h-full">
            
            <!-- Roadmap Card -->
            <div class="bg-white rounded-xl border border-outline-variant shadow-sm flex flex-col flex-1">
                <div class="px-6 py-4 border-b border-outline-variant bg-surface-container/30">
                    <h4 class="font-bold font-headline text-base m-0 text-on-surface">Assigned Roadmap</h4>
                </div>
                <div class="p-6 flex-1 flex flex-col text-center justify-center">
                    @if (Model.Roadmap != null)
                    {
                        <div class="mb-6">
                            <span class="material-symbols-outlined text-4xl text-secondary mb-3">map</span>
                            <h4 class="font-bold font-headline text-lg text-on-surface">@Model.Roadmap.Title</h4>
                            <p class="text-sm text-on-surface/60 max-w-xs mx-auto mb-4">@Model.Roadmap.Description</p>
                            <div class="bg-secondary/5 border border-secondary/10 text-secondary text-sm px-4 py-3 rounded-lg inline-flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">check_circle</span>
                                <span class="text-left font-medium">All @Model.GroupMembers.Count members are enrolled in this roadmap!</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-6 opacity-60">
                            <span class="material-symbols-outlined text-5xl text-tertiary mb-3">warning</span>
                            <h5 class="font-bold text-on-surface text-lg mb-1">No Roadmap Assigned</h5>
                            <p class="text-sm text-on-surface/70">Select a roadmap below to enroll all students.</p>
                        </div>
                    }
                    
                    <div class="mt-auto border-t border-outline-variant pt-5 text-left">
                        <label class="block text-[11px] font-bold uppercase tracking-widest text-on-surface/60 mb-2">Assign / Change Roadmap</label>
                        <form asp-action="AssignRoadmap" method="post" id="assignRoadmapForm" class="space-y-3">
                            <input type="hidden" name="groupId" value="@Model.Id" />
                            <select name="roadmapId" id="roadmapSelect" class="w-full bg-surface-container-lowest border border-outline-variant focus:border-secondary focus:ring-1 focus:ring-secondary rounded-lg px-4 py-2.5 text-sm text-on-surface" required>
                                <option value="">-- Choose a Roadmap --</option>
                                @foreach (var r in roadmaps)
                                {
                                    <option value="@r.Id" data-title="@r.Title">@r.Title (Est: @r.EstimatedTotalHours hrs)</option>
                                }
                            </select>
                            <button type="button" class="w-full bg-secondary text-white py-2.5 rounded-lg font-medium text-sm hover:bg-[#2d9047] transition-colors gdg-shadow border-0" onclick="confirmRoadmapAssignment()">
                                Assign Selected Roadmap
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Invite Card -->
            <div class="bg-white rounded-xl border border-outline-variant shadow-sm flex flex-col flex-1">
                <div class="px-6 py-4 border-b border-outline-variant flex items-center gap-2 bg-surface-container/30">
                    <span class="material-symbols-outlined text-on-surface/70">qr_code_scanner</span>
                    <h4 class="font-bold font-headline text-base m-0 text-on-surface">Invite Students</h4>
                </div>
                <div class="p-6 text-center flex flex-col justify-center items-center">
                    <p class="text-sm text-on-surface/60 mb-3">Students can join automatically using this code</p>
                    <h3 class="text-4xl font-black text-primary tracking-[0.2em] font-mono mb-4 bg-primary/5 py-2 px-6 rounded-lg border border-primary/20">@Model.JoinCode</h3>
                    <div class="bg-white p-2 border border-outline-variant rounded-lg shadow-sm mb-4">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@Url.Action("Join", "Group", new { code = Model.JoinCode }, Context.Request.Scheme)" alt="QR Code" class="w-32 h-32" />
                    </div>
                    <button class="px-5 py-2 rounded-lg font-medium text-sm text-primary border border-primary hover:bg-primary/5 transition-colors flex items-center gap-2" onclick="navigator.clipboard.writeText('@Url.Action("Join", "Group", new { code = Model.JoinCode }, Context.Request.Scheme)')">
                        <span class="material-symbols-outlined text-sm">content_copy</span> Copy Invite Link
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmRoadmapAssignment() {
            var form = document.getElementById('assignRoadmapForm');
            var select = document.getElementById('roadmapSelect');
            var roadmapId = select.value;
            var roadmapTitle = select.options[select.selectedIndex]?.getAttribute('data-title');
            
            var memberCount = @(Model.GroupMembers.Count);

            if (!roadmapId) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Please select a roadmap first!',
                    confirmButtonColor: '#4285f4'
                });
                return;
            }

            Swal.fire({
                title: 'Are you sure?',
                text: `This will enroll all ${memberCount} members into '${roadmapTitle}'. Proceed?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#34a853',
                cancelButtonColor: '#ea4335',
                confirmButtonText: 'Yes, enroll them!'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }
    </script>
}
