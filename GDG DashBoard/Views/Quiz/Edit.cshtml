@model GDG_DashBoard.DAL.Models.Quiz
@{
    ViewData["Title"] = "Edit Quiz";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Edit Quiz";

    // Serialize existing data for JS
    var questionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Questions.OrderBy(q => q.OrderIndex).Select(q => new {
            content = q.Content,
            orderIndex = q.OrderIndex,
            options = q.Options.Select(o => new { text = o.Text, isCorrect = o.IsCorrect })
        })
    );
}

<div class="flex items-center gap-4 mb-6">
    <a asp-action="Details" asp-route-id="@Model.Id"
       class="w-10 h-10 bg-white border border-outline-variant/20 rounded-xl flex items-center justify-center hover:bg-surface-container transition-all shadow-sm">
        <span class="material-symbols-outlined text-on-surface/60">arrow_back</span>
    </a>
    <div>
        <h2 class="text-2xl font-black font-headline text-on-surface">Edit Quiz</h2>
        <p class="text-sm text-on-surface/50">Modify questions and settings for this knowledge check.</p>
    </div>
</div>

<div class="max-w-4xl mx-auto pb-20">
    <div class="bg-white rounded-3xl p-6 md:p-8 shadow-sm border border-outline-variant/20 mb-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        <h3 class="text-xl font-black font-headline text-on-surface mb-6 relative z-10">Quiz Details</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
            <div class="md:col-span-2">
                <label class="block text-sm font-bold text-on-surface mb-2">Quiz Title *</label>
                <input type="text" id="quizTitle" value="@Model.Title"
                       class="w-full h-12 px-4 rounded-xl border-2 border-outline-variant/30 bg-surface-container-high focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-sm font-bold outline-none" required />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-bold text-on-surface mb-2">Description</label>
                <textarea id="quizDesc" rows="3"
                          class="w-full p-4 rounded-xl border-2 border-outline-variant/30 bg-surface-container-high focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all text-sm outline-none resize-none">@Model.Description</textarea>
            </div>
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Passing Score (%) *</label>
                <input type="number" id="quizPassingScore" min="1" max="100" value="@Model.PassingScorePercentage"
                       class="w-full h-12 px-4 rounded-xl border-2 border-outline-variant/30 bg-surface-container-high focus:bg-white focus:border-secondary focus:ring-4 focus:ring-secondary/10 transition-all text-sm font-black text-secondary outline-none" required />
            </div>
        </div>
    </div>

    <div class="flex items-center justify-between mb-6">
        <div>
            <h3 class="text-xl font-black font-headline text-on-surface">Questions</h3>
            <p class="text-sm text-on-surface/50">Edit, remove, or add questions.</p>
        </div>
        <button type="button" id="addQuestionBtn"
                class="px-4 py-2 bg-secondary/10 text-secondary rounded-xl text-sm font-bold hover:bg-secondary hover:text-white transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">add</span> Add Question
        </button>
    </div>

    <div id="questionsContainer" class="space-y-6"></div>
    <div id="emptyState" class="hidden text-center py-12 bg-white/50 border border-dashed border-outline-variant/30 rounded-3xl mb-6">
        <span class="material-symbols-outlined text-4xl text-on-surface/20 mb-3">quiz</span>
        <h3 class="text-lg font-bold text-on-surface">No Questions</h3>
    </div>

    <div class="mt-8 flex justify-end gap-3">
        <a asp-action="Details" asp-route-id="@Model.Id"
           class="px-6 py-3.5 border border-outline-variant/30 text-on-surface/70 rounded-xl text-sm font-bold hover:bg-surface-container transition-all">
            Cancel
        </a>
        <button type="button" id="saveQuizBtn"
                class="px-8 py-3.5 bg-secondary text-white rounded-xl text-sm font-black tracking-wide shadow-lg shadow-secondary/25 hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">save</span> Save Changes
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const QUIZ_ID = '@Model.Id';
        let questionIndex = 0;

        const questionsContainer = document.getElementById('questionsContainer');
        const emptyState = document.getElementById('emptyState');

        function createQuestionElement(index, prefill = null) {
            const div = document.createElement('div');
            div.className = 'question-block bg-white rounded-3xl p-6 shadow-sm border border-outline-variant/20 relative';
            div.dataset.index = index;

            div.innerHTML = `
                <div class="flex justify-between items-start mb-4">
                    <h4 class="text-sm font-black text-secondary uppercase tracking-wider">Question <span class="q-num">${index + 1}</span></h4>
                    <button type="button" class="remove-q-btn w-8 h-8 flex items-center justify-center rounded-lg text-error/60 hover:bg-error/10 hover:text-error transition-colors">
                        <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                </div>
                <textarea rows="2" class="q-content w-full p-4 mb-4 rounded-xl border-2 border-outline-variant/30 bg-surface-container-high focus:bg-white focus:border-primary transition-all text-sm font-bold outline-none resize-none" placeholder="What is the question?">${prefill?.content ?? ''}</textarea>
                <div class="opts-container space-y-3 pl-2 md:pl-6 border-l-2 border-outline-variant/20"></div>
                <button type="button" class="add-opt-btn mt-4 ml-2 md:ml-6 px-3 py-1.5 bg-surface-container-highest text-on-surface/70 rounded-lg text-xs font-bold hover:bg-outline-variant/20 transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">add</span> Add Option
                </button>
            `;

            div.querySelector('.remove-q-btn').addEventListener('click', () => {
                div.remove();
                updateQuestionNumbers();
            });

            const optsContainer = div.querySelector('.opts-container');
            const addOptBtn = div.querySelector('.add-opt-btn');
            let optCount = 0;

            const addOption = (prefillOpt = null) => {
                const optDiv = document.createElement('div');
                optDiv.className = 'opt-block flex items-center gap-3 relative group';
                const uniqueId = `opt_${index}_${optCount++}`;
                optDiv.innerHTML = `
                    <div class="relative flex items-center shrink-0">
                        <input type="radio" name="correct_${index}" id="${uniqueId}" class="peer sr-only" ${prefillOpt?.isCorrect ? 'checked' : ''} />
                        <label for="${uniqueId}" class="w-6 h-6 rounded-full border-2 border-outline-variant/50 peer-checked:border-secondary peer-checked:bg-secondary flex items-center justify-center cursor-pointer transition-all shadow-sm">
                            <span class="material-symbols-outlined text-white text-[14px] opacity-0 peer-checked:opacity-100 transition-opacity" style="font-variation-settings:'FILL' 1;">check</span>
                        </label>
                    </div>
                    <input type="text" class="opt-text flex-1 h-10 px-4 rounded-xl border-2 border-transparent bg-surface-container-high focus:bg-white focus:border-outline-variant/50 transition-all text-sm outline-none" value="${prefillOpt?.text ?? ''}" placeholder="Option text..." required />
                    <button type="button" class="remove-opt-btn w-8 h-8 rounded-lg text-on-surface/30 hover:text-error hover:bg-error/10 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-[16px]">close</span>
                    </button>
                `;
                optDiv.querySelector('.remove-opt-btn').addEventListener('click', () => optDiv.remove());
                optsContainer.appendChild(optDiv);
            };

            if (prefill?.options?.length) {
                prefill.options.forEach(o => addOption(o));
            } else {
                addOption(); addOption();
            }

            addOptBtn.addEventListener('click', () => addOption());
            return div;
        }

        function updateQuestionNumbers() {
            const blocks = document.querySelectorAll('.question-block');
            emptyState.classList.toggle('hidden', blocks.length > 0);
            blocks.forEach((block, idx) => {
                block.querySelector('.q-num').textContent = idx + 1;
                block.querySelectorAll('input[type="radio"]').forEach(r => r.name = `correct_req_${idx}`);
            });
        }

        // Prefill existing questions
        const existingQuestions = @Html.Raw(questionsJson);
        existingQuestions.forEach(q => {
            questionsContainer.appendChild(createQuestionElement(questionIndex++, q));
        });
        updateQuestionNumbers();

        document.getElementById('addQuestionBtn').addEventListener('click', () => {
            questionsContainer.appendChild(createQuestionElement(questionIndex++));
            updateQuestionNumbers();
        });

        document.getElementById('saveQuizBtn').addEventListener('click', async () => {
            const title = document.getElementById('quizTitle').value.trim();
            const desc = document.getElementById('quizDesc').value.trim();
            const passScore = parseInt(document.getElementById('quizPassingScore').value, 10);

            if (!title) return alert('Quiz Title is required.');
            if (passScore < 1 || passScore > 100) return alert('Valid passing score is required.');

            const rawQs = document.querySelectorAll('.question-block');
            if (rawQs.length === 0) return alert('Add at least one question.');

            let questions = [];
            let isValid = true;

            rawQs.forEach((qBlock, qIdx) => {
                const content = qBlock.querySelector('.q-content').value.trim();
                const optBlocks = qBlock.querySelectorAll('.opt-block');
                if (!content) { alert(`Question ${qIdx + 1} is empty.`); isValid = false; return; }
                if (optBlocks.length < 2) { alert(`Question ${qIdx + 1} needs at least 2 options.`); isValid = false; return; }

                let options = [];
                let correctCount = 0;
                optBlocks.forEach(ob => {
                    const text = ob.querySelector('.opt-text').value.trim();
                    const isCorrect = ob.querySelector('input[type="radio"]').checked;
                    if (!text) { alert(`An option in Question ${qIdx + 1} is empty.`); isValid = false; return; }
                    if (isCorrect) correctCount++;
                    options.push({ text, isCorrect });
                });
                if (correctCount === 0) { alert(`Question ${qIdx + 1} must have a correct option.`); isValid = false; return; }
                questions.push({ content, orderIndex: qIdx, options });
            });

            if (!isValid) return;

            const btn = document.getElementById('saveQuizBtn');
            const original = btn.innerHTML;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Saving...';
            btn.disabled = true;

            try {
                const res = await fetch(`/Quiz/Edit/${QUIZ_ID}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, description: desc, passingScorePercentage: passScore, questions })
                });
                const data = await res.json();
                if (data.success) window.location.href = data.redirectUrl;
                else alert('Something went wrong.');
            } catch (err) {
                console.error(err);
                alert('Error saving changes.');
            } finally {
                btn.innerHTML = original;
                btn.disabled = false;
            }
        });
    </script>
}
