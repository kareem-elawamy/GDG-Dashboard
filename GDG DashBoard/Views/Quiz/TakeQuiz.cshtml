@model GDG_DashBoard.DAL.Models.Quiz
@{
    ViewData["Title"] = "Knowledge Check";
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = Model.Title;
    bool alreadyPassed = ViewBag.AlreadyPassed ?? false;
    int score = ViewBag.Score ?? 0;
}

<div class="max-w-3xl mx-auto pb-16 mt-4">
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-outline-variant/20 mb-8 relative overflow-hidden text-center">
        <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        <div class="w-16 h-16 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-3xl">psychology</span>
        </div>
        <h2 class="text-3xl font-black font-headline text-on-surface mb-2">@Model.Title</h2>
        <p class="text-on-surface/60 mb-4 max-w-xl mx-auto">@Model.Description</p>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-surface-container rounded-xl text-sm font-bold text-on-surface/70">
            <span class="material-symbols-outlined text-[18px]">verified</span> Passing Score: @Model.PassingScorePercentage%
        </div>
    </div>

    @if (alreadyPassed)
    {
        <div class="bg-secondary/10 border-2 border-secondary/20 rounded-3xl p-8 text-center mb-8">
            <span class="material-symbols-outlined text-secondary text-5xl mb-3" style="font-variation-settings:'FILL' 1;">check_circle</span>
            <h3 class="text-2xl font-black text-secondary mb-2">You've Already Passed!</h3>
            <p class="text-on-surface/60 font-medium mb-6">Your recorded score is <span class="font-bold">@score%</span>.</p>
            @if (ViewBag.RoadmapId != null)
            {
                <a asp-controller="Member" asp-action="RoadmapDetails" asp-route-id="@ViewBag.RoadmapId" class="px-6 py-3 bg-secondary text-white rounded-xl font-bold shadow-lg shadow-secondary/25 hover:-translate-y-0.5 transition-all inline-flex items-center gap-2">
                    <span class="material-symbols-outlined">arrow_back</span> Return to Roadmap
                </a>
            }
            else
            {
                <a asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Id" class="px-6 py-3 bg-secondary text-white rounded-xl font-bold shadow-lg shadow-secondary/25 hover:-translate-y-0.5 transition-all inline-flex items-center gap-2">
                    <span class="material-symbols-outlined">arrow_back</span> Return to Quiz
                </a>
            }
        </div>
    }
    else
    {
        <form asp-action="SubmitQuiz" method="post" class="space-y-8">
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="roadmapId" value="@ViewBag.RoadmapId" />
            <input type="hidden" name="levelId" value="@ViewBag.LevelId" />

            @{ int qNum = 1; }
            @foreach (var q in Model.Questions)
            {
                <div class="bg-white border border-outline-variant/20 rounded-3xl p-6 md:p-8 shadow-sm relative group">
                    <div class="absolute top-0 left-0 w-1.5 h-full bg-outline-variant/20 group-focus-within:bg-secondary transition-colors rounded-l-3xl"></div>
                    <div class="pl-2">
                        <h4 class="text-lg font-bold text-on-surface mb-6 flex gap-3">
                            <span class="text-secondary font-black">@qNum.</span> @q.Content
                        </h4>
                        
                        <div class="space-y-3">
                            @foreach (var o in q.Options)
                            {
                                <label class="flex items-start gap-4 p-4 border-2 border-transparent bg-surface-container-high rounded-2xl cursor-pointer hover:bg-outline-variant/10 has-[:checked]:bg-secondary/5 has-[:checked]:border-secondary/30 transition-all">
                                    <div class="relative flex items-center shrink-0 mt-0.5">
                                        <input type="radio" name="q_@q.Id" value="@o.Id" class="peer sr-only" required />
                                        <div class="w-5 h-5 rounded-full border-2 border-outline-variant/50 peer-checked:border-secondary peer-checked:border-[6px] transition-all"></div>
                                    </div>
                                    <span class="text-sm font-medium text-on-surface/80">@o.Text</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>
                qNum++;
            }

            <div class="pt-6 border-t border-outline-variant/20 flex items-center justify-between">
                @if (ViewBag.RoadmapId != null)
                {
                    <a asp-controller="Member" asp-action="RoadmapDetails" asp-route-id="@ViewBag.RoadmapId" class="px-6 py-3 font-bold text-on-surface/60 hover:bg-surface-container rounded-xl transition-all">Cancel</a>
                }
                else
                {
                    <a asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Id" class="px-6 py-3 font-bold text-on-surface/60 hover:bg-surface-container rounded-xl transition-all">Cancel Preview</a>
                }
                
                <button type="submit" class="px-8 py-3.5 bg-primary text-white rounded-xl text-sm font-black tracking-wide shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2">
                    Submit Answers <span class="material-symbols-outlined text-[18px]">send</span>
                </button>
            </div>
        </form>
    }
</div>
