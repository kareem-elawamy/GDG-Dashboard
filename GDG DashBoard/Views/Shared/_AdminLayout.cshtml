<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GDG Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/image/gdg_bandung_logo_only.png.png" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#4285f4",
                        "secondary": "#34a853",
                        "tertiary": "#f9ab00",
                        "error": "#ea4335",
                        "on-primary": "#ffffff",
                        "surface": "#fcf9f8",
                        "background": "#f8f9fa",
                        "on-surface": "#1b1b1c",
                        "outline": "#727785",
                        "outline-variant": "#c2c6d5",
                        "surface-container": "#f0eded",
                        "surface-container-low": "#f6f3f2",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#eae7e7",
                        "surface-container-highest": "#e5e2e1",
                        "gdg-blue": "#4285f4",
                        "gdg-green": "#34a853",
                        "gdg-yellow": "#f9ab00",
                        "gdg-red": "#ea4335",
                    },
                    fontFamily: {
                        "headline": ["Manrope", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .sidebar-active {
            background-color: #ffffff;
            color: #4285f4;
            border-left: 4px solid #4285f4;
            font-weight: 600;
        }
        .gdg-shadow {
            box-shadow: 0 1px 2px 0 rgba(60,64,67,.3), 0 1px 3px 1px rgba(60,64,67,.15);
        }
        .step-pulse {
            box-shadow: 0 0 0 0 rgba(66,133,244,0.4);
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(66,133,244,0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(66,133,244,0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(66,133,244,0); }
        }
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; color: #1b1b1c; }
    </style>
</head>
<body class="antialiased selection:bg-primary/10">

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════════════ -->
    <aside class="hidden md:flex bg-[#f6f3f2] h-screen w-64 fixed left-0 top-0 flex-col p-6 space-y-4 font-body font-medium text-sm tracking-wide text-on-surface z-[60] border-r border-outline-variant/20">
        <div class="mb-8 flex flex-col">
            <img src="~/image/gdg_bandung_logo_only.png.png" asp-append-version="true" alt="GDG Logo" class="w-12 h-auto mb-2" onerror="this.onerror=null; this.src='https://via.placeholder.com/48x48?text=G';" />
            <h1 class="text-xl font-bold font-headline text-on-surface">GDG Dashboard</h1>
            <p class="text-[10px] text-on-surface/50 font-bold uppercase tracking-wider">Google Developer Groups</p>
        </div>

        <nav class="flex-1 space-y-2 mt-4">
            
            <a class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:text-gdg-blue hover:bg-surface-container-high transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "sidebar-active" : "text-on-surface/70")"
               asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined">home</span>
                <span>Home</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="pt-4 pb-2 px-4 uppercase text-[10px] tracking-wider font-bold text-on-surface/40">Admin Menu</div>
                
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:text-gdg-blue hover:bg-surface-container-high transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "sidebar-active" : "text-on-surface/70")"
                   asp-controller="Admin" asp-action="Index">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Admin Dashboard</span>
                </a>
                
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:text-gdg-blue hover:bg-surface-container-high transition-all @(ViewContext.RouteData.Values["action"]?.ToString() == "Onboard" ? "sidebar-active" : "text-on-surface/70")"
                   asp-controller="Admin" asp-action="Onboard">
                    <span class="material-symbols-outlined" style="@(ViewContext.RouteData.Values["action"]?.ToString() == "Onboard" ? "font-variation-settings:'FILL' 1;" : "")">person_add</span>
                    <span>Add New Member</span>
                </a>
            }

            @if (!User.IsInRole("Instructor"))
            {
                <div class="pt-4 pb-2 px-4 uppercase text-[10px] tracking-wider font-bold text-on-surface/40">Instructor Menu</div>
                
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:text-gdg-blue hover:bg-surface-container-high transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Instructor" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "sidebar-active" : "text-on-surface/70")"
                   asp-controller="Instructor" asp-action="Index">
                    <span class="material-symbols-outlined">groups</span>
                    <span>Instructor Console</span>
                </a>
            }
            <!-- Other dummy views removed for explicitly wired navigation as requested -->
        </nav>

        <div class="pt-6 mt-auto border-t border-outline-variant/20 space-y-1">
            <div class="pb-2 px-4 uppercase text-[10px] tracking-wider font-bold text-on-surface/40">My Learning</div>
            <a class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:text-gdg-blue hover:bg-surface-container-high transition-all mb-4 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Member" ? "sidebar-active" : "text-on-surface/70")"
               asp-controller="Member" asp-action="Index">
                <span class="material-symbols-outlined">person</span>
                <span>My Profile</span>
            </a>
            
            <hr class="border-outline-variant/20 mb-2" />
            
            <a class="flex items-center space-x-3 text-on-surface/70 px-4 py-3 hover:text-gdg-blue hover:bg-surface-container-high transition-all rounded-lg" href="#">
                <span class="material-symbols-outlined">settings</span>
                <span>Settings</span>
            </a>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="flex w-full items-center space-x-3 text-on-surface/70 px-4 py-3 hover:text-gdg-red hover:bg-gdg-red/5 transition-all rounded-lg">
                    <span class="material-symbols-outlined">logout</span>
                    <span>Logout</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- ══ MAIN AREA ═════════════════════════════════════════════════════════ -->
    <div class="md:ml-64 min-h-screen flex flex-col">

        <!-- TOP APP BAR -->
        <header class="bg-[#fcf9f8]/80 backdrop-blur-xl sticky top-0 z-50 flex justify-between items-center w-full px-8 h-16 shadow-[0_12px_40px_rgba(27,27,28,0.04)] border-b border-outline-variant/10">
            <div class="flex items-center space-x-4">
                <span class="text-xl font-bold font-headline tracking-tight text-on-surface">@ViewData["PageTitle"]</span>
            </div>
            <div class="flex items-center space-x-4">
                <button class="p-2 rounded-full hover:bg-surface-container-high transition-colors active:scale-95">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <div class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center overflow-hidden border border-outline-variant/20">
                    <span class="material-symbols-outlined text-gdg-blue" style="font-variation-settings: 'FILL' 1;">account_circle</span>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="flex-1 p-8">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
