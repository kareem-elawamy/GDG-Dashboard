@model GDG_DashBoard.ViewModels.Admin.OnboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Onboard Member";
    ViewData["PageTitle"] = "Onboard Member";
}

<div class="max-w-2xl mx-auto space-y-8">

    <!-- Page Header -->
    <div>
        <nav class="flex text-[11px] font-bold tracking-wider text-primary uppercase mb-1">
            <ol class="flex items-center space-x-2">
                <li><a asp-controller="Admin" asp-action="Index" class="hover:underline">Management</a></li>
                <li class="flex items-center space-x-2">
                    <span class="material-symbols-outlined text-[12px]">chevron_right</span>
                    <span>Onboard Member</span>
                </li>
            </ol>
        </nav>
        <h2 class="text-3xl font-bold font-headline tracking-tight text-on-surface">New Member Setup</h2>
        <p class="text-on-surface/50 text-sm mt-1">Create an account for a new community member. They will receive a
            link to set their own password.</p>
        </div>

        <!-- ══ SUCCESS STATE ══════════════════════════════════════════════════════ -->
        @if (Model.OnboardingSucceeded)
        {
            <div class="bg-secondary/5 border border-secondary/30 rounded-2xl p-8">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-secondary text-2xl"
                              style="font-variation-settings:'FILL' 1;">check_circle</span>
                    </div>
                    <div class="flex-1">
                        <h3 class="font-bold font-headline text-lg text-on-surface mb-1">Member Onboarded Successfully!</h3>
                        <p class="text-sm text-on-surface/60 mb-6">
                            The account for <strong>@Model.FullName</strong> (@Model.Email) has been created.
                            Share the setup token below with the member so they can set their password.
                        </p>
                    </div>
                </div>
                <div class="mt-6 flex gap-3">
                    <a asp-controller="Admin" asp-action="AllMembers"
                           class="px-5 py-2.5 bg-primary text-white rounded-lg font-medium text-sm hover:bg-[#1a73e8] transition-colors flex items-center gap-2">
                        Return to Member Directory
                    </a>
                    <a asp-controller="Admin" asp-action="Onboard"
                           class="px-5 py-2.5 bg-white border border-outline-variant rounded-lg font-medium text-sm hover:bg-surface-container transition-colors ml-auto">
                        Onboard Another
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- ══ FORM ════════════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-2xl border border-outline-variant shadow-sm overflow-hidden">
                <div class="px-8 py-6 border-b border-outline-variant bg-surface-container/30 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">person_add</span>
                    <h3 class="font-bold font-headline text-lg">Member Information</h3>
                </div>

                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="mx-8 mt-6 bg-error/5 border border-error/20 rounded-xl p-4 flex items-start gap-3">
                        <span class="material-symbols-outlined text-error text-lg mt-0.5">error</span>
                        <div asp-validation-summary="All" class="text-sm text-error"></div>
                    </div>
                }

                <form asp-controller="Admin" asp-action="Onboard" method="post" class="p-8 space-y-6">
                    @Html.AntiForgeryToken()

                    <!-- Email -->
                    <div>
                        <label asp-for="Email"
                               class="block text-[10px] font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                        <input asp-for="Email"
                               class="w-full bg-surface-container-low border border-outline-variant focus:ring-2 focus:ring-primary/30 focus:border-primary rounded-lg text-sm px-4 py-3 placeholder:text-on-surface/30 transition-all"
                               placeholder="member@gdg.community" autocomplete="off" />
                        <span asp-validation-for="Email" class="text-xs text-error mt-1 block"></span>
                    </div>

                    <!-- Full Name -->
                    <div>
                        <label asp-for="FullName"
                               class="block text-[10px] font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                        <input asp-for="FullName"
                               class="w-full bg-surface-container-low border border-outline-variant focus:ring-2 focus:ring-primary/30 focus:border-primary rounded-lg text-sm px-4 py-3 placeholder:text-on-surface/30 transition-all"
                               placeholder="John Doe" />
                        <span asp-validation-for="FullName" class="text-xs text-error mt-1 block"></span>
                    </div>

                    <!-- Season + Role (Grid) -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="Season"
                                   class="block text-[10px] font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                            <input asp-for="Season"
                                   class="w-full bg-surface-container-low border border-outline-variant focus:ring-2 focus:ring-primary/30 focus:border-primary rounded-lg text-sm px-4 py-3 placeholder:text-on-surface/30 transition-all"
                                   placeholder="e.g. Spring 2025" />
                            <span asp-validation-for="Season" class="text-xs text-error mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Role"
                                   class="block text-[10px] font-bold uppercase tracking-widest text-on-surface/50 mb-2"></label>
                            <select asp-for="Role"
                                    class="w-full bg-surface-container-low border border-outline-variant focus:ring-2 focus:ring-primary/30 focus:border-primary rounded-lg text-sm px-4 py-3 transition-all">
                                <option value="Admin">Admin</option>
                                <option value="Mentor">Mentor</option>
                                <option value="Organizer">Organizer</option>
                                <option value="Speaker">Speaker</option>
                                <option value="Member" selected>Member</option>
                            </select>
                            <span asp-validation-for="Role" class="text-xs text-error mt-1 block"></span>
                        </div>
                    </div>

                    <!-- Info box -->
                    <div class="bg-primary/5 border border-primary/20 rounded-xl p-4 flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary text-lg mt-0.5">info</span>
                        <p class="text-sm text-on-surface/70 leading-relaxed">
                            The account is created without a password. A <strong>setup token</strong> will be generated that you
                            can share with the member to let them define their own credentials.
                        </p>
                    </div>

                    <!-- Submit -->
                    <div class="flex items-center gap-4 pt-2">
                        <button type="submit"
                                class="bg-primary px-8 py-3 rounded-lg font-bold text-sm text-white gdg-shadow hover:bg-[#1a73e8] hover:shadow-lg active:scale-[0.98] transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">person_add</span>
                            Create Account
                        </button>
                        <a asp-controller="Admin" asp-action="Index"
                               class="px-5 py-3 text-on-surface/60 text-sm font-medium hover:text-on-surface transition-colors">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        }
    </div>

    @section Scripts {
        <script>
            function copyToken() {
                const token = document.getElementById('reset-token').textContent.trim();
                navigator.clipboard.writeText(token).then(() => {
                    const btn = event.target.closest('button');
                    const icon = btn.querySelector('.material-symbols-outlined');
                    icon.textContent = 'check';
                    setTimeout(() => icon.textContent = 'content_copy', 2000);
                });
            }
        </script>
    }
