@model List<GDG_DashBoard.BLL.Dtos.Admin.MemberOverviewDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "All Members";
    ViewData["PageTitle"] = "Member Directory";
}

<div class="max-w-7xl mx-auto space-y-8">

    <!-- Header & Search -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl font-bold font-headline tracking-tight text-on-surface">All Members</h2>
        </div>
        
        <div class="flex items-center gap-4 w-full md:w-auto">
            <form method="get" asp-action="AllMembers" class="relative w-full md:w-80" id="searchForm">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface/40 text-lg">search</span>
                <input type="text" id="searchInput" name="searchString" value="@ViewData["SearchString"]" placeholder="Search by name or email..." 
                       class="w-full pl-10 pr-4 py-2.5 bg-white border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-sm font-medium" />
            </form>
            <a asp-action="Onboard" class="bg-primary px-5 py-2.5 rounded-lg font-medium text-sm text-white gdg-shadow hover:bg-[#1a73e8] transition-all flex items-center gap-2 whitespace-nowrap">
                <span class="material-symbols-outlined text-sm">person_add</span>
                <span class="hidden sm:inline">Onboard</span>
            </a>
        </div>
    </div>

    <!-- Feedback Messages -->
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="bg-secondary/5 border border-secondary/30 rounded-xl p-4 flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">check_circle</span>
            <p class="text-sm font-medium text-secondary">@success</p>
        </div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="bg-error/5 border border-error/30 rounded-xl p-4 flex items-center gap-3">
            <span class="material-symbols-outlined text-error">error</span>
            <p class="text-sm font-medium text-error">@error</p>
        </div>
    }

    <!-- Members Table -->
    <div class="bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center bg-surface-container/30">
            <h4 class="font-bold font-headline text-base">Directory</h4>
            <span class="text-on-surface/40 text-xs font-medium" id="memberCountLabel">@Model.Count members found</span>
        </div>
        
        <div class="overflow-x-auto relative min-h-[400px]">
            <!-- Loading Overlay -->
            <div id="loadingOverlay" class="absolute inset-0 bg-white/60 backdrop-blur-sm z-10 hidden flex flex-col items-center justify-center transition-all opacity-0">
                <div class="w-8 h-8 rounded-full border-4 border-primary border-t-transparent animate-spin"></div>
                <span class="mt-2 text-xs font-bold text-on-surface/50 tracking-widest uppercase">Searching...</span>
            </div>

            <div id="membersTableContainer">
                <partial name="_MembersTablePartial" model="Model" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const searchForm = document.getElementById('searchForm');
            const membersTableContainer = document.getElementById('membersTableContainer');
            const loadingOverlay = document.getElementById('loadingOverlay');
            const memberCountLabel = document.getElementById('memberCountLabel');

            // Debounce utility
            function debounce(func, wait) {
                let timeout;
                return function executedFunction(...args) {
                    const later = () => {
                        clearTimeout(timeout);
                        func(...args);
                    };
                    clearTimeout(timeout);
                    timeout = setTimeout(later, wait);
                };
            }

            // Perform AJAX Fetch
            const performSearch = async (query) => {
                // Prevent empty submit via JS since we can just query string it
                
                // Show loading spinner safely
                loadingOverlay.classList.remove('hidden');
                // Tiny delay to allow display:block to apply before fading in
                setTimeout(() => loadingOverlay.classList.add('opacity-100'), 10);
                
                try {
                    const url = new URL(window.location.href.split('?')[0]);
                    const params = new URLSearchParams(window.location.search);
                    
                    if (query) params.set('searchString', query);
                    else params.delete('searchString');
                    
                    // Update URL without reloading to maintain state
                    window.history.replaceState({}, '', `${url.pathname}?${params}`);

                    const requestUrl = `${url.pathname}?${params}`;

                    const response = await fetch(requestUrl, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (response.ok) {
                        const html = await response.text();
                        membersTableContainer.innerHTML = html;
                        
                        // Parse rows count
                        const rows = membersTableContainer.querySelectorAll('tbody tr');
                        // if the row is the 'no results' row, there are 0 actual active members found
                        const hasNoResults = membersTableContainer.querySelector('.material-symbols-outlined.text-4xl.block');
                        
                        if (hasNoResults) {
                            memberCountLabel.textContent = '0 members found';
                        } else {
                            memberCountLabel.textContent = `${rows.length} members found`;
                        }
                    }
                } catch (error) {
                    console.error('Error fetching search results:', error);
                } finally {
                    // Hide Loader
                    loadingOverlay.classList.remove('opacity-100');
                    setTimeout(() => loadingOverlay.classList.add('hidden'), 300); // Wait for transition
                }
            };

            const debouncedSearch = debounce((e) => {
                performSearch(e.target.value);
            }, 300);

            // Listeners
            searchInput.addEventListener('input', debouncedSearch);

            // Prevent strict form submission if user presses enter
            searchForm.addEventListener('submit', function(e) {
                e.preventDefault();
                performSearch(searchInput.value);
            });
        });
    </script>
}
